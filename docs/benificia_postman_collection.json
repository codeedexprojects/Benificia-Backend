                  ]
                },
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/api/v1/user/photo",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "user", "photo"]
                }
              }
            }

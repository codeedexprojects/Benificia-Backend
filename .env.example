NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/benificia

# Redis
REDIS_URL=redis://localhost:6379

# JWT — must be 32+ characters
JWT_SECRET=change_me_to_a_long_random_secret_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key — must be 32+ characters
ENCRYPTION_KEY=change_me_to_a_32_char_encryption_key!!

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
AWS_S3_BUCKET=your-s3-bucket-name

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173

# AI Server
AI_SERVER_URL=https://ai.yourdomain.com
AI_SERVER_API_KEY=your_ai_server_api_key

# Surepass KYC
SUREPASS_API_KEY=your_surepass_api_key

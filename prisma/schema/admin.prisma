// ════════════════════════════════════════════════════════════
// prisma/schema/admin.prisma
// MODULE 7 — Admin, Scoring Config & Notification Templates
// ════════════════════════════════════════════════════════════

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String    @db.VarChar(255)
  role         AdminRole @default(support_agent)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  auditLogs       AdminAuditLog[]
  tieupAuditLogs  TieupAuditLog[]
  addedCompanies  InsuranceCompany[]
  managedProducts InsuranceProduct[]
  scoringConfigs  ScoringConfig[]
  sessions        AdminSession[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("admin_users")
}

model AdminSession {
  id               String    @id @default(uuid()) @db.Uuid
  adminId          String    @map("admin_id") @db.Uuid
  sessionId        String    @unique @map("session_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(64)
  isRevoked        Boolean   @default(false) @map("is_revoked")
  expiresAt        DateTime  @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([sessionId])
  @@index([isRevoked])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model AdminAuditLog {
  id          String  @id @default(uuid()) @db.Uuid
  adminId     String  @map("admin_id") @db.Uuid
  action      String  @db.VarChar(200)
  targetTable String? @map("target_table") @db.VarChar(100)
  targetId    String? @map("target_id") @db.VarChar(255)
  ipAddress   String? @map("ip_address") @db.Inet
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  admin AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([targetTable])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model ScoringConfig {
  id String @id @default(uuid()) @db.Uuid

  // Factor weights — must sum to 100
  savingsRatioWeight  Float @default(40) @map("savings_ratio_weight")
  debtRatioWeight     Float @default(40) @map("debt_ratio_weight")
  emergencyFundWeight Float @default(20) @map("emergency_fund_weight")

  // Band thresholds — excellent = above goodThreshold
  poorThreshold    Int @default(40) @map("poor_threshold")
  averageThreshold Int @default(60) @map("average_threshold")
  goodThreshold    Int @default(80) @map("good_threshold")

  isActive Boolean @default(true) @map("is_active")
  // Only one config active at a time; previous kept for history

  updatedBy String   @map("updated_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  admin AdminUser @relation(fields: [updatedBy], references: [id])

  @@index([isActive])
  @@map("scoring_configs")
}

model NotificationTemplate {
  id  String @id @default(uuid()) @db.Uuid
  key String @unique @db.VarChar(100)
  // e.g. otp_registration / kyc_verified / recommendation_ready

  channel String  @db.VarChar(20)
  // email / sms
  subject String? @db.VarChar(255)
  // for email only
  body    String  @db.Text
  // supports {{user_name}}, {{otp_code}} etc

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([channel])
  @@index([isActive])
  @@map("notification_templates")
}

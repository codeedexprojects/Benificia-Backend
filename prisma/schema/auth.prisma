// ════════════════════════════════════════════════════════════
// prisma/schema/auth.prisma
// MODULE 1 — Authentication & Users
// ════════════════════════════════════════════════════════════

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique @db.VarChar(255)
  passwordHash String       @map("password_hash") @db.VarChar(255)
  profileStage ProfileStage @default(auth_complete) @map("profile_stage")
  kycStatus    KycStatus    @default(pending) @map("kyc_status")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  // Relations
  profile               UserProfile?
  incomeProfile         IncomeProfile?
  expenseProfile        ExpenseProfile?
  assetLiabilityProfile AssetLiabilityProfile?
  riskProfile           RiskProfile?
  financialGoals        FinancialGoal[]
  kyc_consents          KycConsent[]
  kycAuditLogs          KycAuditLog[]
  authSessions          AuthSession[]
  otpLogs               OtpLog[]
  aiRecommendations     AiRecommendation[]
  insuranceInterests    InsuranceInterest[]

  @@index([email])
  @@index([profileStage])
  @@index([kycStatus])
  @@index([isActive])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("users")
}

model AuthSession {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @map("refresh_token_hash") @db.VarChar(255)
  deviceId         String?  @map("device_id") @db.VarChar(255)
  ipAddress        String?  @map("ip_address") @db.Inet
  userAgent        String?  @map("user_agent") @db.VarChar(500)
  isRevoked        Boolean  @default(false) @map("is_revoked")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([isRevoked])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model OtpLog {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String?    @map("user_id") @db.Uuid
  email        String     @db.VarChar(255)
  purpose      OtpPurpose
  otpCodeHash  String     @map("otp_code_hash") @db.VarChar(255)
  attemptCount Int        @default(1) @map("attempt_count")
  isVerified   Boolean    @default(false) @map("is_verified")
  expiresAt    DateTime   @map("expires_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
  @@index([expiresAt])
  @@map("otp_logs")
}

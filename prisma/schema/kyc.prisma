// ════════════════════════════════════════════════════════════
// prisma/schema/kyc.prisma
// MODULE 2 — KYC & Profile
// ════════════════════════════════════════════════════════════

model UserProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // Auto-filled from Aadhaar — never editable by user
  fullName     String?   @map("full_name") @db.VarChar(255)
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  gender       Gender?
  photoS3Key   String?   @map("photo_s3_key") @db.VarChar(500)
  addressLine1 String?   @map("address_line1") @db.VarChar(500)
  landmark     String?   @db.VarChar(255)
  locality     String?   @db.VarChar(255)
  city         String?   @db.VarChar(100)
  district     String?   @db.VarChar(100)
  state        String?   @db.VarChar(100)
  pincode      String?   @db.VarChar(10)
  country      String    @default("India") @db.VarChar(100)

  // KYC metadata — set automatically by Surepass
  aadhaarLast4  String?    @map("aadhaar_last4") @db.VarChar(4)
  kycMethod     KycMethod? @map("kyc_method")
  kycVerifiedAt DateTime?  @map("kyc_verified_at")

  // Manual fields — filled by user after Aadhaar
  maritalStatus          MaritalStatus? @map("marital_status")
  numberOfDependents     Int            @default(0) @map("number_of_dependents")
  childrenAges           Int[]          @map("children_ages")
  occupation             String?        @db.VarChar(100)
  employer               String?        @db.VarChar(100)
  incomeType             IncomeType?    @map("income_type")
  retirementAge          Int            @default(60) @map("retirement_age")
  isPrimaryEarner        Boolean        @default(true) @map("is_primary_earner")
  dependentsRelyOnIncome Boolean        @default(true) @map("dependents_rely_on_income")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([city])
  @@index([state])
  @@index([kycVerifiedAt])
  @@map("user_profiles")
}

model KycConsent {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  consentType String   @map("consent_type") @db.VarChar(100)
  consentText String   @map("consent_text") @db.Text
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  consentedAt DateTime @default(now()) @map("consented_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consentedAt])
  @@map("kyc_consents")
}

model KycAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid

  // initiated / otp_sent / verified / otp_failed /
  // otp_expired / max_attempts_reached
  action      String   @db.VarChar(100)
  method      String?  @db.VarChar(50)
  referenceId String?  @map("reference_id") @db.VarChar(255)
  ipAddress   String?  @map("ip_address") @db.Inet
  outcome     String?  @db.VarChar(50)
  errorReason String?  @map("error_reason") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("kyc_audit_logs")
}
